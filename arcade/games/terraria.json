{
    "game_id": "terraria",
    "display_name": "Terraria",
    "steam_app_id": 105600,
    "category": "sandbox",
    "min_ram_mb": 2048,
    "recommended_ram_mb": 4096,
    "min_disk_gb": 2,
    "supports_clustering": false,
    "max_cluster_maps": 0,
    "maps": [
        {"id": "small", "name": "Small World", "dlc": false},
        {"id": "medium", "name": "Medium World", "dlc": false},
        {"id": "large", "name": "Large World", "dlc": false}
    ],
    "config_files": [
        {"path": "tshock/config.json", "template": "terraria/config.json.j2"}
    ],
    "startup_command": "TShock.Server.exe -port {{game}} -maxplayers {{max_players}} -world {{world_path}} -autocreate {{world_size}} -worldname {{world_name}} -password {{server_password}}",
    "default_settings": {
        "max_players": 16,
        "world_size": 3,
        "difficulty": "normal",
        "spawn_protection_radius": 10,
        "hard_core_only": false,
        "pvp_mode": "disabled",
        "anti_cheat": true,
        "whitelist_only": true
    },
    "whitelist_file": "",
    "linuxgsm_id": "",
    "query_protocol": "tshock",
    "notes": "Default game port 7777. Uses TShock server mod for Linux. World sizes: 1=small, 2=medium, 3=large. Runs via mono on Linux."
}
